---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import GuideWideLayout from '../../layouts/GuideWideLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('guides');
  // This site publishes only the customer-specific (Bunzl) guide.
  return posts
    .filter((post) => post.id.startsWith('customer/'))
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const Layout = post.data.width === 'wide' ? GuideWideLayout : PostLayout;
---

<Layout
  title={post.data.title}
  date={post.data.date}
  topic={post.data.topic}
  readTime={post.data.readTime}
  description={post.data.excerpt}
  noindex={post.data.unlisted}
  minimalChrome={post.id.startsWith('customer/')}
>
  <Content />
</Layout>
