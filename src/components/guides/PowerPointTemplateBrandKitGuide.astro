<script>
(function () {
const guideRoot = document.querySelector('.cgp-root');

/* ─── Fade-in on scroll ─── */
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
}, { threshold: 0.08 });
document.querySelectorAll('.fade-in').forEach(el => io.observe(el));

/* ─── Scroll progress + back-to-top + active nav ─── */
const progress = document.getElementById('scroll-progress');
const backBtn = document.getElementById('back-to-top');
const navLinks = guideRoot ? Array.from(guideRoot.querySelectorAll('.nav-links a[href^="#"]')) : [];
const sections = navLinks.map(a => document.querySelector(a.getAttribute('href'))).filter(Boolean);
window.addEventListener('scroll', () => {
  const h = document.documentElement;
  const scrolled = (h.scrollTop) / (h.scrollHeight - h.clientHeight);
  progress.style.width = (scrolled * 100) + '%';
  backBtn.classList.toggle('show', h.scrollTop > 600);
  let current = '';
  sections.forEach(s => { if (s.getBoundingClientRect().top <= 120) current = '#' + s.id; });
  navLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === current));
});

/* ─── Theme handled globally by the site header ─── */

/* ─── Tabs ─── */
function switchTab(group, id, btn) {
  document.querySelectorAll('[data-tabgroup="' + group + '"] .tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('[data-tabpanel="' + group + '"]').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(id).classList.add('active');
}

/* ─── Expand / collapse all steps in a group ─── */
function toggleAllSteps(groupId) {
  const group = document.getElementById(groupId);
  if (!group) return;
  const items = group.querySelectorAll('details.step');
  const anyClosed = Array.from(items).some(d => !d.open);
  items.forEach(d => d.open = anyClosed);
}

/* ─── Lightbox ─── */
function openImg(src, caption) {
  document.getElementById('lightbox-body').innerHTML =
    '<img src="' + src + '" alt="' + (caption || '') + '" style="display:block;max-width:90vw;max-height:80vh;object-fit:contain;border-radius:8px;">';
  document.getElementById('lightbox-caption').textContent = caption || '';
  document.getElementById('lightbox').classList.add('active');
  document.body.style.overflow = 'hidden';
}
function closeLightbox(e) {
  if (e && e.target.id === 'lightbox-content') return;
  document.getElementById('lightbox').classList.remove('active');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

/* ─── Toast ─── */
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 1800);
}

/* ─── Brand Inputs worksheet (localStorage) ─── */
function initWorksheet() {
  const inputs = document.querySelectorAll('.worksheet input');
  inputs.forEach(inp => {
    const key = 'ws-' + inp.dataset.key;
    const v = localStorage.getItem(key);
    if (v) inp.value = v;
    inp.addEventListener('input', () => localStorage.setItem(key, inp.value));
  });
}
function saveWorksheet() { showToast('Brand inputs saved locally ✓'); }
function clearWorksheet() {
  document.querySelectorAll('.worksheet input').forEach(inp => { inp.value = ''; localStorage.removeItem('ws-' + inp.dataset.key); });
  showToast('Worksheet cleared');
}

/* ─── QA Checklist (localStorage + progress) ─── */
function initChecklist() {
  const items = document.querySelectorAll('.checklist li');
  items.forEach(li => {
    const key = 'qa-' + li.dataset.key;
    if (localStorage.getItem(key) === '1') li.classList.add('checked');
    li.addEventListener('click', () => {
      li.classList.toggle('checked');
      localStorage.setItem(key, li.classList.contains('checked') ? '1' : '0');
      updateChecklist();
    });
  });
  updateChecklist();
}
function updateChecklist() {
  const items = document.querySelectorAll('.checklist li');
  const done = document.querySelectorAll('.checklist li.checked').length;
  const total = items.length;
  const bar = document.getElementById('progress-bar');
  const count = document.getElementById('progress-count');
  if (bar) bar.style.width = total ? (done / total * 100) + '%' : '0%';
  if (count) count.textContent = done;
  const congrats = document.getElementById('congrats-msg');
  if (congrats) congrats.classList.toggle('show', done === total && total > 0);
}

/* Initialise worksheet + checklist immediately (Astro modules run after DOMContentLoaded). */
initWorksheet(); initChecklist();

  window.clearWorksheet = clearWorksheet;
  window.closeLightbox = closeLightbox;
  window.openImg = openImg;
  window.saveWorksheet = saveWorksheet;
  window.switchTab = switchTab;
  window.toggleAllSteps = toggleAllSteps;
})();
</script>
