<script>
(function () {
  const guideRoot = document.querySelector('.cge-root');

(function() {
  'use strict';

  /* ─── Sample File Downloads ─── */
  window.downloadSample = function(filename, content, mimeType) {
    var blob = new Blob([content], {type: mimeType || 'text/plain'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
  };

  /* ─── Lightbox for Access Images ─── */
  window.openLightbox = function(src, caption, type) {
    var overlay = document.getElementById('lightbox');
    var body = document.getElementById('lightbox-body');
    var cap = document.getElementById('lightbox-caption');
    var cls = type === 'desktop' ? 'desktop-image' : '';
    body.innerHTML = '<img src="' + src + '" alt="' + caption + '" class="' + cls + '" style="display:block;max-width:90vw;max-height:80vh;object-fit:contain;">';
    cap.textContent = caption;
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  };

  window.closeLightbox = function(e) {
    var content = document.getElementById('lightbox-content');
    if (e.target === content || content.contains(e.target)) {
      if (e.target.classList.contains('lightbox-close') || e.target.closest('.lightbox-close')) {
        // allow close button
      } else {
        return;
      }
    }
    var overlay = document.getElementById('lightbox');
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  };

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var overlay = document.getElementById('lightbox');
      if (overlay && overlay.classList.contains('active')) {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      }
    }
  });

  /* ─── Theme handled globally by the site header ─── */

  /* ─── Practice Reveal Toggle ─── */
  window.toggleReveal = function(btn) {
    var actions = btn.closest('.practice-actions') || btn.parentElement;
    var reveal = actions.querySelector('.practice-reveal');
    var isOpen = reveal.style.display !== 'none' && reveal.style.display !== '';
    reveal.style.display = isOpen ? 'none' : 'block';
    btn.textContent = isOpen ? 'See our suggestion ▼' : 'Hide suggestion ▲';
  };

  /* ─── Evolve Stepper ─── */
  window.switchEvolve = function(level) {
    document.querySelectorAll('.evolve-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.evolve-panel').forEach(function(p) { p.classList.remove('active'); });
    document.querySelector('.evolve-tab[data-level="' + level + '"]').classList.add('active');
    document.getElementById('evolve-' + level).classList.add('active');
  };

  /* ─── Capability Card Expand/Collapse ─── */
  window.toggleCapability = function(header) {
    const card = header.closest('.capability-card');
    const detail = card.querySelector('.capability-detail');
    const inner = detail.querySelector('.capability-detail-inner');
    const wasOpen = card.classList.contains('open');
    card.classList.toggle('open');
    if (!wasOpen) {
      detail.style.maxHeight = inner.scrollHeight + 'px';
    } else {
      detail.style.maxHeight = '0';
      // Scroll back to card if it's above the viewport
      const rect = card.getBoundingClientRect();
      if (rect.top < 0) {
        card.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  };

  // Inject collapse buttons into all capability-detail-inner elements
  document.querySelectorAll('.capability-detail-inner').forEach(function(inner) {
    var btn = document.createElement('button');
    btn.className = 'collapse-btn';
    btn.textContent = '▲ Collapse';
    btn.addEventListener('click', function() {
      var card = inner.closest('.capability-card');
      var header = card.querySelector('.capability-header');
      toggleCapability(header);
    });
    inner.appendChild(btn);
  });

  /* ─── Accordion ─── */
  window.toggleAccordion = function(header) {
    const item = header.closest('.accordion-item');
    const body = item.querySelector('.accordion-body');
    const inner = body.querySelector('.accordion-body-inner');
    item.classList.toggle('open');
    header.setAttribute('aria-expanded', item.classList.contains('open'));
    if (item.classList.contains('open')) {
      body.style.maxHeight = inner.scrollHeight + 'px';
    } else {
      body.style.maxHeight = '0';
    }
  };

  /* ─── Tabs ─── */
  window.switchTab = function(btn, panelId) {
    document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    const panel = document.getElementById(panelId);
    panel.classList.add('active');
    // Re-observe fade-in elements inside newly visible panel
    panel.querySelectorAll('.fade-in:not(.visible)').forEach(el => fadeObserver.observe(el));
  };

  /* ─── Copy Prompt ─── */
  window.copyPrompt = function(el) {
    const hint = el.querySelector('.copy-hint');
    const text = el.innerText.replace(/📋\s*Click to copy$/i, '').replace(/📋\s*Copied ✓$/i, '').trim();
    navigator.clipboard.writeText(text).then(() => {
      showToast('Copied!');
      if (hint) { hint.textContent = 'Copied ✓'; setTimeout(() => { hint.textContent = 'Click to copy'; }, 1500); }
    }).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast('Copied!');
      if (hint) { hint.textContent = 'Copied ✓'; setTimeout(() => { hint.textContent = 'Click to copy'; }, 1500); }
    });
  };

  /* ─── Toast ─── */
  let toastTimer;
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2000);
  }

  /* ─── Checklist ─── */
  const STORAGE_KEY = 'copilot-excel-checklist';
  let checks = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
  if (!Array.isArray(checks) || checks.length !== 10) checks = new Array(10).fill(false);

  function renderChecklist() {
    const items = document.querySelectorAll('.checklist-item');
    let done = 0;
    items.forEach((item, i) => {
      const cb = item.querySelector('.checklist-checkbox');
      if (checks[i]) {
        cb.classList.add('checked');
        cb.setAttribute('aria-checked', 'true');
        item.classList.add('completed');
        done++;
      } else {
        cb.classList.remove('checked');
        cb.setAttribute('aria-checked', 'false');
        item.classList.remove('completed');
      }
    });
    document.getElementById('progress-count').textContent = done;
    document.getElementById('progress-bar').style.width = (done / 10 * 100) + '%';
    document.getElementById('congrats-msg').classList.toggle('visible', done === 10);
  }

  window.toggleCheck = function(cb) {
    const item = cb.closest('.checklist-item');
    const idx = parseInt(item.getAttribute('data-check'), 10);
    checks[idx] = !checks[idx];
    localStorage.setItem(STORAGE_KEY, JSON.stringify(checks));
    cb.style.transform = 'scale(1.2)';
    setTimeout(() => { cb.style.transform = ''; }, 200);
    renderChecklist();
  };

  renderChecklist();

  /* ─── Fade-in on Scroll ─── */
  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        const idx = Array.from(document.querySelectorAll('.fade-in:not(.visible)')).indexOf(entry.target);
        const delay = Math.max(0, idx) * 60;
        setTimeout(() => entry.target.classList.add('visible'), Math.min(delay, 300));
        fadeObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.fade-in').forEach(el => fadeObserver.observe(el));

  /* ─── Active Nav Link ─── */
  const sections = guideRoot ? guideRoot.querySelectorAll('section[id]') : [];
  const navLinks = guideRoot ? guideRoot.querySelectorAll('.nav-links a[href^="#"]') : [];
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        navLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === '#' + id);
        });
      }
    });
  }, { rootMargin: '-80px 0px -50% 0px', threshold: 0 });

  sections.forEach(s => navObserver.observe(s));

  /* ─── Scroll Progress & Back to Top ─── */
  const progressBar = document.getElementById('scroll-progress');
  const backToTop = document.getElementById('back-to-top');
  window.addEventListener('scroll', function() {
    const scrollTop = window.scrollY || document.documentElement.scrollTop;
    const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrollPercent = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    if (progressBar) progressBar.style.width = scrollPercent + '%';
    if (backToTop) backToTop.classList.toggle('visible', scrollTop > 400);
  }, { passive: true });

  /* ─── Detect OS for Keyboard Shortcut ─── */
  const isMac = /Mac|iPod|iPhone|iPad/.test(navigator.platform) || (navigator.userAgentData && navigator.userAgentData.platform === 'macOS');
  const kbdEl = document.querySelector('.search-btn span');
  if (kbdEl && !isMac) kbdEl.textContent = 'Ctrl+K';

})();

})();
</script>
